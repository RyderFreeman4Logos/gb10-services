[Unit]
Description=llm-guard-proxy guard wrapper for GB10 model upstreams
After=network.target vllm-embedding.service vllm-aeon-27b-dflash.service querit-4b-reranker.service
Wants=vllm-embedding.service vllm-aeon-27b-dflash.service querit-4b-reranker.service

[Service]
Type=simple
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadOnlyPaths=/home/obj/.config/llm-guard-proxy /home/obj/.local/bin/llm-guard-proxy
ReadWritePaths=/home/obj/.local/state /home/obj/.local/state/llm-guard-proxy
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
LockPersonality=true
MemoryDenyWriteExecute=true
RestrictRealtime=true
SystemCallArchitectures=native
# Guard is CPU-side; keep it from unbounded growth / swap thrash.
# Primary model memory is bounded on the docker-*.scope of each model unit.
MemoryMax=2G
MemoryHigh=1536M
MemorySwapMax=0
OOMScoreAdjust=-200
ExecStartPre=/usr/bin/test -r /home/obj/.config/llm-guard-proxy/config.toml
ExecStartPre=/usr/bin/mkdir -p /home/obj/.local/state/llm-guard-proxy
ExecStart=/home/obj/.local/bin/llm-guard-proxy --config /home/obj/.config/llm-guard-proxy/config.toml
Restart=on-failure
RestartSec=5
TimeoutStopSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
