[Unit]
Description=llm-guard-proxy guard wrapper for GB10 model upstreams
After=network.target vllm-embedding.service vllm-aeon-27b-dflash.service querit-4b-reranker.service
# Ordering only: Guard does not own backend lifecycle or participate in text recovery.

[Service]
Type=simple
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadOnlyPaths=/home/obj/.config/llm-guard-proxy /home/obj/.local/bin/llm-guard-proxy
ReadWritePaths=/home/obj/.local/state /home/obj/.local/state/llm-guard-proxy
CacheDirectory=llm-guard-proxy-evidence
CacheDirectoryMode=0700
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
LockPersonality=true
MemoryDenyWriteExecute=true
RestrictRealtime=true
SystemCallArchitectures=native
MemoryHigh=1792M
MemoryMax=2G
MemorySwapMax=0
OOMScoreAdjust=-200
ExecStartPre=/usr/bin/test -r /home/obj/.config/llm-guard-proxy/config.toml
ExecStartPre=/usr/bin/mkdir -p /home/obj/.local/state/llm-guard-proxy

ExecStart=/home/obj/.local/bin/llm-guard-proxy --config /home/obj/.config/llm-guard-proxy/config.toml
Restart=on-failure
RestartSec=5
TimeoutStopSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
