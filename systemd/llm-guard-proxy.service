[Unit]
Description=llm-guard-proxy guard wrapper for GB10 model upstreams
After=network.target
# Start independently so the integrated guardian protects backend startup.

[Service]
Type=simple
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadOnlyPaths=/home/obj/.config/llm-guard-proxy /home/obj/.local/bin/llm-guard-proxy
# The integrated guardian must retain a writable cgroup.kill descriptor for the
# dynamically generated text Docker scope. Registration state itself lives in %t.
ReadWritePaths=/home/obj/.local/state /home/obj/.local/state/llm-guard-proxy /sys/fs/cgroup
CacheDirectory=llm-guard-proxy-evidence
CacheDirectoryMode=0700
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
LockPersonality=true
MemoryDenyWriteExecute=true
RestrictRealtime=true
SystemCallArchitectures=native
MemoryHigh=1792M
MemoryMax=2G
MemorySwapMax=0
OOMScoreAdjust=-200
ExecStartPre=/usr/bin/test -r /home/obj/.config/llm-guard-proxy/config.toml
ExecStartPre=/usr/bin/mkdir -p /home/obj/.local/state/llm-guard-proxy

ExecStart=/home/obj/.local/bin/llm-guard-proxy --config /home/obj/.config/llm-guard-proxy/config.toml --guardian-runtime-dir %t/gb10-memory-guardian
Restart=on-failure
RestartSec=5
TimeoutStopSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
