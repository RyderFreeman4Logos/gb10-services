# Temporary source-controlled raw backend. The separately tested adapter keeps
# its DeepInfra-native listener on Tailnet :18014; this backend remains
# loopback-only on :18015 for bounded lab work.
[Unit]
Description=Temporary Querit-4B vLLM pooling canary backend (loopback :18015)
After=network.target
StartLimitIntervalSec=600
StartLimitBurst=1

[Service]
Type=simple
UMask=0077
Environment=DOCKER_HOST=unix:///run/user/1001/docker.sock
Environment=HF_HUB_OFFLINE=1
Environment=TRANSFORMERS_OFFLINE=1

# Wrapper/docker-CLI only. Docker bounds the 18 GiB canary separately.
MemoryMax=256M
OOMScoreAdjust=500
Restart=no
TimeoutStartSec=1800
TimeoutStopSec=60

ExecCondition=/usr/bin/env -i HOME=/home/obj PATH=/usr/bin:/bin LC_ALL=C DOCKER_HOST=unix:///run/user/1001/docker.sock /usr/bin/bash --noprofile --norc /home/obj/.local/bin/gb10_verify_vllm_no_swap.sh --unit /home/obj/.config/systemd/user/vllm-querit-4b-canary-backend.service
ExecCondition=/home/obj/.local/bin/gb10_querit_canary_preflight.py
ExecStartPre=/usr/bin/install -d -m 0700 %t/gb10-vllm-cids
ExecStartPre=/usr/bin/env -i HOME=/home/obj PATH=/usr/bin:/bin LC_ALL=C DOCKER_HOST=unix:///run/user/1001/docker.sock /usr/bin/bash --noprofile --norc /home/obj/.local/bin/gb10_verify_vllm_no_swap.sh --cleanup --container vllm-querit-4b-canary --cidfile %t/gb10-vllm-cids/vllm-querit-4b-canary-backend.cid
ExecStart=/usr/bin/docker run --rm --cidfile=%t/gb10-vllm-cids/vllm-querit-4b-canary-backend.cid --name vllm-querit-4b-canary \
  --cgroup-parent app.slice \
  --gpus all --ipc host \
  -p 127.0.0.1:18015:8000 \
  -v /home/obj/models/querit-4b-vllm:/home/obj/models/querit-4b-vllm:ro \
  -e HF_HUB_OFFLINE=1 \
  -e TRANSFORMERS_OFFLINE=1 \
  --memory 18g \
  --memory-swap 18g \
  --memory-swappiness 0 \
  --oom-score-adj 500 \
  --entrypoint python3 \
  ghcr.io/aeon-7/aeon-vllm-ultimate@sha256:c15e2c4b767c611fc739046129d550d0c347c906a3c9020888acc981f55f137d \
  /usr/local/bin/vllm serve /home/obj/models/querit-4b-vllm \
    --host 0.0.0.0 \
    --port 8000 \
    --served-model-name Querit/Querit-4B Qwen/Qwen3-Reranker-8B qwen3-reranker-8b \
    --runner pooling \
    --dtype bfloat16 \
    --max-model-len 32768 \
    --gpu-memory-utilization 0.17 \
    --kv-cache-memory-bytes 4800M \
    --kv-cache-dtype auto \
    --tensor-parallel-size 1 \
    --pipeline-parallel-size 1 \
    --swap-space 0 \
    --cpu-offload-gb 0 \
    --max-num-batched-tokens 1024 \
    --max-num-seqs 1 \
    --enable-chunked-prefill \
    --max-num-partial-prefills 1 \
    --max-long-partial-prefills 1 \
    --long-prefill-token-threshold 8192 \
    --enforce-eager \
    --chat-template /home/obj/models/querit-4b-vllm/querit-rerank.jinja
ExecStartPost=/usr/bin/env -i HOME=/home/obj PATH=/usr/bin:/bin LC_ALL=C DOCKER_HOST=unix:///run/user/1001/docker.sock /usr/bin/bash --noprofile --norc /home/obj/.local/bin/gb10_verify_vllm_no_swap.sh --unit /home/obj/.config/systemd/user/vllm-querit-4b-canary-backend.service --container vllm-querit-4b-canary
ExecStartPost=/home/obj/.local/bin/gb10_service_ready.sh rerank http://127.0.0.1:18015 Querit/Querit-4B --deadline 300
ExecStop=/usr/bin/env -i HOME=/home/obj PATH=/usr/bin:/bin LC_ALL=C DOCKER_HOST=unix:///run/user/1001/docker.sock /usr/bin/bash --noprofile --norc /home/obj/.local/bin/gb10_verify_vllm_no_swap.sh --cleanup --container vllm-querit-4b-canary --cidfile %t/gb10-vllm-cids/vllm-querit-4b-canary-backend.cid
ExecStopPost=/usr/bin/env -i HOME=/home/obj PATH=/usr/bin:/bin LC_ALL=C DOCKER_HOST=unix:///run/user/1001/docker.sock /usr/bin/bash --noprofile --norc /home/obj/.local/bin/gb10_verify_vllm_no_swap.sh --cleanup --container vllm-querit-4b-canary --cidfile %t/gb10-vllm-cids/vllm-querit-4b-canary-backend.cid

StandardOutput=journal
StandardError=journal
