# Querit-4B vLLM pooling reranker (AEON v0.25.1, raw Tailnet :18013).
# The llm-guard-proxy adapter on :18009/:18003 forwards rerank requests to
# this backend; clients (CodeSeek, mempal, verbatim) see a DeepInfra-compatible
# contract through the adapter.
[Unit]
Description=Querit-4B vLLM pooling reranker (AEON v0.25.1, raw Tailnet :18013)
After=network.target
Conflicts=querit-4b-reranker.service vllm-qwen3-reranker-8b.service
StartLimitIntervalSec=600
StartLimitBurst=1

[Service]
Type=simple
Environment=DOCKER_HOST=unix:///run/user/1001/docker.sock
Environment=HF_HUB_OFFLINE=1
Environment=TRANSFORMERS_OFFLINE=1

# Wrapper/docker-CLI only. Docker owns the 18 GiB no-swap service cap.
MemoryMax=256M
MemorySwapMax=0
OOMScoreAdjust=500
Restart=no
TimeoutStartSec=1800
TimeoutStopSec=60

ExecStartPre=-/usr/bin/docker rm -f querit-4b-vllm
ExecStart=/usr/bin/docker run --rm --name querit-4b-vllm \
  --cgroup-parent app.slice \
  --gpus all --ipc host \
  -p 100.105.4.92:18013:8000 \
  -v /home/obj/models/querit-4b-vllm:/home/obj/models/querit-4b-vllm:ro \
  -e HF_HUB_OFFLINE=1 \
  -e TRANSFORMERS_OFFLINE=1 \
  --memory 18g \
  --memory-swap 18g \
  --memory-swappiness 0 \
  --oom-score-adj 500 \
  --entrypoint python3 \
  ghcr.io/aeon-7/aeon-vllm-ultimate@sha256:c15e2c4b767c611fc739046129d550d0c347c906a3c9020888acc981f55f137d \
  /usr/local/bin/vllm serve /home/obj/models/querit-4b-vllm \
    --host 0.0.0.0 \
    --port 8000 \
    --served-model-name Querit/Querit-4B Qwen/Qwen3-Reranker-8B qwen3-reranker-8b \
    --runner pooling \
    --dtype bfloat16 \
    --max-model-len 32768 \
    --gpu-memory-utilization 0.17 \
    --kv-cache-memory-bytes 4800M \
    --kv-cache-dtype auto \
    --tensor-parallel-size 1 \
    --pipeline-parallel-size 1 \
    --cpu-offload-gb 0 \
    --max-num-batched-tokens 1024 \
    --max-num-seqs 1 \
    --enable-chunked-prefill \
    --max-num-partial-prefills 1 \
    --max-long-partial-prefills 1 \
    --long-prefill-token-threshold 8192 \
    --enforce-eager \
    --chat-template /home/obj/models/querit-4b-vllm/querit-rerank.jinja
ExecStartPost=/home/obj/.local/bin/gb10_service_ready.sh rerank http://100.105.4.92:18013 Querit/Querit-4B --deadline 300
ExecStop=/usr/bin/timeout --signal=TERM --kill-after=5 30 /usr/bin/docker stop --time 20 querit-4b-vllm

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
